/* ====================== RENDER HELPERS ====================== */
const $ = s => document.querySelector(s);
const esc = s => (s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
const pPill = p => `<span class="pill p${p}">Prioridad ${p}</span>`;
const fixUrl = u => u.startsWith("http") ? u : "https://"+u;
function urlText(u){ return u.replace(/^https?:\/\//,'').replace(/\/$/,''); }

/* ---- ORGANISMOS (selección por rubro) ---- */
function renderOrgRubros(){
  $("#orgRubroGrid").innerHTML = RUBROS.map(r=>{
    const c = ORGANISMOS.filter(o=>o.rubros.includes(r.key)).length;
    return `<div class="card" onclick="openRubroOrg('${r.key}')">
      <div style="font-size:30px">${r.icon}</div>
      <h3>${esc(r.nombre)}</h3>
      <div class="excerpt">${esc(r.desc)}</div>
      <div class="meta">${c} organización${c>1?'es':''}</div>
      <div class="open">Ver organizaciones →</div>
    </div>`;
  }).join("");
}
function openRubroOrg(key){
  $("#orgStep1").style.display="none";
  $("#orgStep2").classList.add("show");
  $("#orgRubroTitle").textContent = rubroName(key);
  $("#orgGrid").innerHTML = ORGANISMOS.map((o,i)=>{
    if(!o.rubros.includes(key)) return "";
    return `<div class="card" onclick="openOrg(${i})">
      <div class="tag-row"><span class="pill type">${esc(o.ambito)}</span></div>
      <h3>${esc(o.org)}</h3>
      <div class="meta">📍 ${esc(o.pais)}</div>
      <div class="excerpt">${esc(o.rubro)}</div>
      <div class="open">Ver ficha completa →</div>
    </div>`;
  }).join("");
  document.getElementById("organismos").scrollIntoView({behavior:"smooth"});
}
function resetOrg(){ $("#orgStep2").classList.remove("show"); $("#orgStep1").style.display="block"; document.getElementById("organismos").scrollIntoView({behavior:"smooth"}); }
function openOrg(i){
  const o = ORGANISMOS[i];
  $("#mTags").innerHTML = o.rubros.map(k=>`<span class="pill type">${esc(rubroName(k))}</span>`).join("")+`<span class="pill p3">${esc(o.ambito)}</span>`;
  $("#mTitle").textContent = o.org;
  $("#mBody").innerHTML =
    field("Contacto / canal público", o.contacto.map(c=>`<span class="contact-line">• ${esc(c)}</span>`).join(""), "📞")+
    field("País de acción", esc(o.pais), "🌎")+
    field("Responsable de coordinación sugerido", esc(o.responsable), "🧭")+
    field("Rubro principal que asiste", esc(o.rubro), "📦")+
    field("Experiencia / valor agregado", esc(o.experiencia), "⭐")+
    fieldFem("Uso recomendado por la FEM", esc(o.fem))+
    field("Fuentes", `<div class="links">`+o.fuentes.map(u=>`<a href="${fixUrl(u)}" target="_blank" rel="noopener">${esc(urlText(u))} ↗</a>`).join("")+`</div>`, "🔗");
  showModal();
}

/* ---- PLATAFORMAS ---- */
function renderTipos(){
  const tipos = [...new Set(PLATAFORMAS.map(p=>p.tipo))];
  const icons = {"Agregador ciudadano":"🗂️","Búsqueda de personas":"🔎","Mapa integral":"🗺️","Hospitales y pacientes":"🏥","Buscador / prensa":"📰","Emergencias oficiales":"🚨","Restablecimiento familiar":"👨‍👩‍👧"};
  $("#tipoGrid").innerHTML = tipos.map(t=>{
    const c = PLATAFORMAS.filter(p=>p.tipo===t).length;
    return `<div class="card" onclick="openTipo('${t.replace(/'/g,"\\'")}')">
      <div style="font-size:30px">${icons[t]||"📄"}</div>
      <h3>${esc(t)}</h3>
      <div class="meta">${c} plataforma${c>1?'s':''} disponible${c>1?'s':''}</div>
      <div class="open">Ver plataformas →</div>
    </div>`;
  }).join("");
}
function openTipo(t){
  $("#platStep1").style.display="none";
  const step2=$("#platStep2"); step2.classList.add("show");
  $("#tipoTitle").textContent = t;
  $("#platGrid").innerHTML = PLATAFORMAS.map((p,i)=>{
    if(p.tipo!==t) return "";
    return `<div class="card" onclick="openPlat(${i})">
      <div class="tag-row"><span class="pill ${p.verifLvl}">${vLabel(p.verifLvl)}</span></div>
      <h3>${esc(p.nombre)}</h3>
      <div class="excerpt">${esc(p.contiene)}</div>
      <div class="open">Ver ficha →</div>
    </div>`;
  }).join("");
  document.getElementById("plataformas").scrollIntoView({behavior:"smooth"});
}
function resetPlat(){ $("#platStep2").classList.remove("show"); $("#platStep1").style.display="block"; document.getElementById("plataformas").scrollIntoView({behavior:"smooth"}); }
function vLabel(l){ return l==="ok"?"Oficial / institucional":l==="warn"?"Sin verificar":"Por verificar"; }
function openPlat(i){
  const p = PLATAFORMAS[i];
  $("#mTags").innerHTML = `<span class="pill type">${esc(p.tipo)}</span><span class="pill ${p.verifLvl}">${vLabel(p.verifLvl)}</span>`;
  $("#mTitle").textContent = p.nombre;
  $("#mBody").innerHTML =
    (p.url? field("URL", `<a href="${p.url}" target="_blank" rel="noopener">${esc(urlText(p.url))} ↗</a>`, "🔗") : "")+
    field("Qué contiene", esc(p.contiene), "📋")+
    field("Estado de verificación", esc(p.verif), "✔️")+
    field("Población sensible", esc(p.poblacion), "⚠️")+
    fieldFem("Uso recomendado por la FEM", esc(p.fem))+
    field("Observaciones", esc(p.obs), "📝");
  showModal();
}

/* ---- PROTOCOLO ---- */
function renderProto(){
  $("#protoGrid").innerHTML = PROTOCOLO.map((p,i)=>`
    <div class="card proto" onclick="openProto(${i})">
      <span class="ordernum">${p.orden}</span>
      <div class="tag-row"><span class="pill order">Prioridad ${p.orden}</span></div>
      <h3>${esc(p.rubro)}</h3>
      <div class="excerpt">${esc(p.ejemplos)}</div>
      <div class="open">Ver aliados, riesgos y control →</div>
    </div>`).join("");
}
function openProto(i){
  const p = PROTOCOLO[i];
  $("#mTags").innerHTML = `<span class="pill order">Rubro prioritario ${p.orden}</span>`;
  $("#mTitle").textContent = p.rubro;
  $("#mBody").innerHTML =
    field("Ejemplos concretos", esc(p.ejemplos), "📦")+
    field("Aliados idóneos", esc(p.aliados), "🤝")+
    field("Riesgo operativo", esc(p.riesgo), "⚠️")+
    fieldFem("Recomendación de control", esc(p.control));
  showModal();
}

/* ---- modal utils ---- */
function field(k,v,ico){ return `<div class="field"><div class="k">${ico||""} ${k}</div><div class="v">${v}</div></div>`; }
function fieldFem(k,v){ return `<div class="field"><div class="k">⭐ ${k}</div><div class="v fem">${v}</div></div>`; }
function showModal(){ $("#modalBg").classList.add("show"); document.body.style.overflow="hidden"; }
function closeModal(){ $("#modalBg").classList.remove("show"); document.body.style.overflow=""; }
document.addEventListener("keydown",e=>{ if(e.key==="Escape") closeModal(); });

/* ====================== CHARTS ====================== */
function charts(){
  if(typeof Chart==="undefined") return;
  Chart.defaults.font.family="'Segoe UI',system-ui,sans-serif";
  Chart.defaults.color="#475467";

  const rbLabels=RUBROS.map(r=>r.nombre);
  const rbCounts=RUBROS.map(r=>ORGANISMOS.filter(o=>o.rubros.includes(r.key)).length);
  new Chart($("#chPrioridad"),{type:"bar",data:{labels:RUBROS.map(r=>r.icon),datasets:[{data:rbCounts,backgroundColor:["#00247D","#0033A0","#1668a8","#1d72c2","#3f8fd0","#6ba8dd","#9cc0e8"],borderRadius:7,maxBarThickness:42}]},
    options:{plugins:{legend:{display:false},tooltip:{callbacks:{title:(it)=>rbLabels[it[0].dataIndex]}}},scales:{y:{beginAtZero:true,ticks:{stepSize:2,precision:0},grid:{color:"#eef1f5"}},x:{grid:{display:false},ticks:{font:{size:18}}}}}});

  const ambLabels=["Venezuela","Colombia","Internacional"];
  const ambCounts=ambLabels.map(a=>ORGANISMOS.filter(o=>o.ambito.includes(a)).length);
  new Chart($("#chAmbito"),{type:"bar",data:{labels:ambLabels,datasets:[{data:ambCounts,backgroundColor:["#CF142B","#FCDD09","#0033A0"],borderRadius:8,maxBarThickness:54}]},
    options:{plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,ticks:{stepSize:1,precision:0},grid:{color:"#eef1f5"}},x:{grid:{display:false}}}}});

  const ok=PLATAFORMAS.filter(p=>p.verifLvl==="ok").length;
  const other=PLATAFORMAS.length-ok;
  new Chart($("#chVerif"),{type:"doughnut",data:{labels:["Ciudadana / por verificar","Oficial / institucional"],datasets:[{data:[other,ok],backgroundColor:["#CF142B","#177a3a"],borderWidth:2,borderColor:"#fff"}]},
    options:{plugins:{legend:{position:"bottom",labels:{padding:14,usePointStyle:true,pointStyle:"circle"}}},cutout:"62%"}});
}

/* ====================== INIT ====================== */
renderOrgRubros(); renderTipos(); renderProto(); charts();
</script>
